# =============================================================================
# Environment Variables — Example Configuration
# =============================================================================
# 
# WHAT IS THIS FILE?
#   This is a TEMPLATE for your .env file. Copy it to create your own:
#   
#   copy .env.example .env
#   
#   Then fill in YOUR actual values.
#
# WHY USE .env FILES?
#   - Keeps passwords OUT of your source code
#   - Different settings for development vs production
#   - The .env file is in .gitignore, so it's never uploaded to GitHub
#
# =============================================================================

# ── Database Connection ──────────────────────────────────────────────────────
# These tell PHP how to connect to your MySQL database.
# WAMP default: root user with no password on localhost
DB_HOST=localhost
DB_NAME=kyambogo_voting
DB_USER=root
DB_PASS=
DB_PORT=3306

# ── Email (Resend) Configuration ────────────────────────────────────────────
# Used for registration confirmations, OTP codes, and notifications.
# Sign up at https://resend.com and verify your sending domain first.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@yourdomain.com
RESEND_FROM_NAME="Kyambogo Voting System"

# ── Email (SMTP) Configuration — legacy fallback ───────────────────────────
# Only needed if not using Resend.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS="your-app-password-here"

# FROM_EMAIL = The "from" address that appears in sent emails
FROM_EMAIL=your-email@gmail.com
FROM_NAME="Kyambogo Voting System"

# ── Deployment (Optional) ───────────────────────────────────────────────────
# Only needed if deploying to Vercel
VERCEL_ENV=production
