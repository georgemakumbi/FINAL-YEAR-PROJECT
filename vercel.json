{
  "version": 2,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.6.2"
    }
  },
  "routes": [
    { "src": "/candidates/(.*)", "dest": "/public/candidates/$1" },
    { "src": "/uploads/(.*)", "dest": "/public/uploads/$1" },
    { "src": "/(.*\\.php)", "dest": "/api/index.php" },
    { "src": "/", "dest": "/api/index.php" },
    { "handle": "filesystem" }
  ]
}
